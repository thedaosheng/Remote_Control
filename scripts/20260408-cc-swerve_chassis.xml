  <!-- ===================== 执行器 ===================== -->
  <actuator>
    <!-- ★ 执行器索引表 (共 28 个):
         0-2:  底盘 vx/vy/omega (velocity)
         3-6:  舵轮转向 fl/fr/rl/rr (position, 视觉)
         7-10: 驱动转速 fl/fr/rl/rr (velocity, 视觉)
         11:   升降 lift (position)
         12-17: 左臂 j1-j6 (position)
         18-23: 右臂 j1-j6 (motor/torque)
         24-26: 云台 yaw/pitch/stem (position)
         27:   右夹爪 (position) -->
    <!-- 底盘 3DOF 直接驱动 (无 Z 轴, 高度由刚体约束固定) -->
    <velocity name="chassis_vx_act" joint="chassis_x" kv="200" forcerange="-500 500"/>
    <velocity name="chassis_vy_act" joint="chassis_y" kv="200" forcerange="-500 500"/>
    <velocity name="chassis_omega_act" joint="chassis_yaw" kv="50" forcerange="-100 100"/>

    <!-- 转向位置控制（视觉同步, 舵轮角度跟随 IK）-->
    <position class="steer" name="fl_steer_act" joint="fl_steer"/>
    <position class="steer" name="fr_steer_act" joint="fr_steer"/>
    <position class="steer" name="rl_steer_act" joint="rl_steer"/>
    <position class="steer" name="rr_steer_act" joint="rr_steer"/>

    <!-- 驱动速度控制（视觉同步, 轮子转速匹配地速）-->
    <velocity class="drive" name="fl_drive_act" joint="fl_drive"/>
    <velocity class="drive" name="fr_drive_act" joint="fr_drive"/>
    <velocity class="drive" name="rl_drive_act" joint="rl_drive"/>
    <velocity class="drive" name="rr_drive_act" joint="rr_drive"/>

    <!-- 升降位置控制 (目标高度 m)，索引 8 -->
    <!-- 升降：强过阻尼 (ζ≈1.7)，kv=800 彻底消除振荡 -->
    <!-- kp=20000 补偿 ~20kg 负载重力 (err < 1cm), kv=1200 过阻尼无振荡 -->
    <position name="lift_act" joint="lift_joint" kp="20000" kv="1200"
              forcerange="-5000 5000" ctrlrange="0 0.8"/>

    <!-- 左臂 6 关节 (索引 9~14) -->
    <position class="arm_joint" name="left_j1_act" joint="left_joint1"/>
    <position class="arm_joint" name="left_j2_act" joint="left_joint2"/>
    <position class="arm_joint" name="left_j3_act" joint="left_joint3"/>
    <position class="arm_joint" name="left_j4_act" joint="left_joint4"/>
    <position class="arm_joint" name="left_j5_act" joint="left_joint5"/>
    <position class="arm_joint" name="left_j6_act" joint="left_joint6"/>

    <!-- 右臂 6 关节 - 力矩控制 (索引 15~20) -->
    <motor name="right_j1_motor" joint="right_joint1" ctrllimited="true" ctrlrange="-200 200"/>
    <motor name="right_j2_motor" joint="right_joint2" ctrllimited="true" ctrlrange="-200 200"/>
    <motor name="right_j3_motor" joint="right_joint3" ctrllimited="true" ctrlrange="-200 200"/>
    <motor name="right_j4_motor" joint="right_joint4" ctrllimited="true" ctrlrange="-100 100"/>
    <motor name="right_j5_motor" joint="right_joint5" ctrllimited="true" ctrlrange="-100 100"/>
    <motor name="right_j6_motor" joint="right_joint6" ctrllimited="true" ctrlrange="-100 100"/>

    <!-- 头部云台 yaw + pitch + 高度 slide (索引 21~23) -->
    <position name="head_yaw_act"   joint="head_yaw_joint"
              kp="500" kv="15" forcerange="-100 100" ctrlrange="-1.5708 1.5708"/>
    <position name="head_pitch_act" joint="head_pitch_joint"
              kp="500" kv="15" forcerange="-100 100" ctrlrange="-0.7854 0.7854"/>
    <position name="head_stem_act"  joint="head_stem"
              kp="1500" kv="60" forcerange="-200 200" ctrlrange="-0.05 0.40"/>

    <!-- 右臂夹爪 (索引 24) -->
    <position name="right_gripper_act" tendon="right_gripper_gear"
              kp="200" kv="5" ctrllimited="true" ctrlrange="0 0.0366"
              forcelimited="true" forcerange="-10 10"/>
  </actuator>

  <!-- 右臂夹爪肌腱联动 -->
  <tendon>
    <fixed name="right_gripper_gear">
      <joint joint="right_g2_left_joint" coef="0.5"/>
      <joint joint="right_g2_right_joint" coef="0.5"/>
    </fixed>
  </tendon>

  <!-- 右臂两指同步约束 -->
  <equality>
    <joint joint1="right_g2_left_joint" joint2="right_g2_right_joint"
           polycoef="0 1 0 0 0"/>
  </equality>

</mujoco>
