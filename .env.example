# ============================================================
# Remote_Control env vars — copy to .env and fill in values
# ============================================================
# DO NOT commit .env to git (already in .gitignore).
# See SECURITY.md for the LIVEKIT_API_SECRET rotation procedure.

# --- LiveKit (Aliyun relay) ---
LIVEKIT_URL=ws://39.102.113.104:7880
LIVEKIT_API_KEY=teleop_key
LIVEKIT_API_SECRET=

# --- ROS 2 (Orin + CangJie only) ---
ROS_DOMAIN_ID=0
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
# Path is per-machine; replace <user> with bit (Orin) or cangjie (CangJie)
CYCLONEDDS_URI=file:///home/<user>/cyclonedds.xml

# --- LiveKit identities (per participant; pick one matching the machine) ---
# Orin: zed-mini-sender / zed-mini-pose-recv / orin-cloud2ros-bridge
# CangJie: cangjie-ros2cloud-bridge
# ASUS: edward-asus-teleop
LK_IDENTITY=
