<?xml version="1.0"?>
<!-- 云台调试：STL 已修正坐标，关节归零，三色区分 -->
<robot name="rentou_debug" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <link name="world"/>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://airbot_description/meshes/rentou_base_link.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="gray"><color rgba="0.6 0.6 0.6 1"/></material>
    </visual>
  </link>

  <joint name="world_to_base" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="world"/>
    <child link="base_link"/>
  </joint>

  <link name="link1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://airbot_description/meshes/rentou_link1.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="green"><color rgba="0.2 0.8 0.2 1"/></material>
    </visual>
  </link>

  <joint name="joint1" type="revolute">
    <origin xyz="0.02350 0.03700 0.00000" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="link1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="10.0" velocity="3.14"/>
  </joint>

  <link name="link2">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://airbot_description/meshes/rentou_link2.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="pink"><color rgba="0.9 0.4 0.5 1"/></material>
    </visual>
  </link>

  <joint name="joint2" type="revolute">
    <origin xyz="0.05200 0.02350 0.00001" rpy="0 0 0"/>
    <parent link="link1"/>
    <child link="link2"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.57080" upper="1.57080" effort="10.0" velocity="3.14"/>
  </joint>

</robot>
